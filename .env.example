# ─── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Anthropic / Claude AI (required for AI Agents page) ─────────────────────
# Get this from: console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Cloud deployment notes ───────────────────────────────────────────────────
# Netlify: set vars in Site → Site configuration → Environment variables
# Vercel:  set vars in Project → Settings → Environment Variables
# Never commit .env files — this file is safe to commit (.env is in .gitignore)
