# One DSD Equity Program — Agent Backend Configuration
# Copy this file to .env and fill in your values

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection (recommend claude-sonnet-4-6 for speed, claude-opus-4-6 for depth)
COORDINATOR_MODEL=claude-opus-4-6
AGENT_MODEL=claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── CORS — list of allowed frontend origins ──────────────────────────────────
# Comma-separated. Add your GitHub Pages URL and any custom domain.
CORS_ORIGINS=http://localhost:8080,https://gary-design63.github.io

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to backend/ dir, or absolute)
DB_PATH=./data/equity_program.db

# ── Agent Behavior ────────────────────────────────────────────────────────────
# Max tokens per agent response
AGENT_MAX_TOKENS=4096

# Enable extended thinking for deep analysis (true/false)
EXTENDED_THINKING=false

# How many recent messages to include in agent context
CONTEXT_WINDOW_MESSAGES=20

# ── Scheduled Jobs ────────────────────────────────────────────────────────────
# Run risk/action monitoring (cron syntax)
MONITOR_CRON=0 8 * * 1-5

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret for validating requests from the frontend
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=change_this_to_a_random_secret
