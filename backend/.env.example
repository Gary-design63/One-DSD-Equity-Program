# One DSD Equity Program — Agent Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000
HOST=0.0.0.0

# ── CORS — allowed frontend origins (comma-separated, no trailing slash) ──────
# Local dev:   http://localhost:8080
# Production:  https://gary-design63.github.io
CORS_ORIGINS=http://localhost:8080,https://gary-design63.github.io

# ── AI Models ─────────────────────────────────────────────────────────────────

# Coordinator agent — handles routing and cross-domain synthesis
COORDINATOR_MODEL=claude-opus-4-6

# Specialist agents — policy, metrics, workflows, learning, risk, community
AGENT_MODEL=claude-sonnet-4-6

# Max tokens per agent response
AGENT_MAX_TOKENS=4096

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite file path (relative to backend/ dir, or absolute)
DB_PATH=./data/equity_program.db

# ── Conversation Context ──────────────────────────────────────────────────────

# Number of prior messages to include in each agent's context window
CONTEXT_WINDOW_MESSAGES=20

# ── Scheduled Monitoring ──────────────────────────────────────────────────────

# Cron expression for the automated morning risk/action scan
# Default: weekdays at 8:00am server time
MONITOR_CRON=0 8 * * 1-5
